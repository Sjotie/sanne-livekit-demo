#!/usr/bin/env bash
set -euo pipefail

if [ ! -f ".env" ]; then
  echo "Missing .env. Copy .env.example to .env and set PIKA_DEV_KEY." >&2
  exit 1
fi

set -a
source .env
set +a

uv run --with "requests>=2.32.5" python "$HOME/.codex/skills/pikastream-video-meeting/scripts/pikastreaming_videomeeting.py" "$@"
