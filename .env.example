PIKA_DEV_KEY=your-pika-dev-key-here

# Baseten-hosted Sanne voice agent
BASETEN_API_KEY=your-baseten-api-key-here
BASETEN_AGENT_WS_URL=wss://chain-or-model-id.api.baseten.co/environments/production/websocket

# Provider choices for the Baseten agent runtime
SANNE_AGENT_LLM_PROVIDER=baseten
SANNE_AGENT_LLM_MODEL=your-llm-model-id
SANNE_AGENT_STT_PROVIDER=baseten
SANNE_AGENT_TTS_PROVIDER=omnivoice
SANNE_AGENT_VOICE_ID=voice_Sanne_20260413101430
BASETEN_OPENAI_BASE_URL=https://inference.baseten.co/v1
BASETEN_LLM_MODEL=your-baseten-model-api-model-name
BASETEN_STT_MODEL_ID=your-baseten-streaming-transcription-model-id
BASETEN_OMNIVOICE_MODEL_ID=your-baseten-omnivoice-model-id

# Provider switches used by apps/baseten-livekit-agent
SANNE_AGENT_NAME=sanne
SANNE_LLM_PROVIDER=baseten
SANNE_STT_PROVIDER=mistral
SANNE_TTS_PROVIDER=mistral
MISTRAL_TTS_VOICE=your-mistral-custom-voice-id
SANNE_ENDPOINT_MIN_DELAY=0.15
SANNE_ENDPOINT_MAX_DELAY=0.8
SANNE_TURN_DETECTOR=false

# Local development
SANNE_AGENT_LOCAL_WS_URL=ws://127.0.0.1:8787/ws

# LiveKit media layer
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key-here
LIVEKIT_API_SECRET=your-livekit-api-secret-here
LIVEKIT_DEFAULT_ROOM=sanne-demo
LIVEKIT_AGENT_NAME=sanne

# Temporary LiveKit worker provider copied from the PA demo.
# Baseten/OmniVoice will replace this once the media loop is proven.
MISTRAL_API_KEY=your-mistral-api-key-here
